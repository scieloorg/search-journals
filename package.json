{
  "name": "search-journals",
  "version": "1.0.0",
  "description": "Aplicação responsável por tornar os artigos ciêntificos da rede SciELO pesquisável.",
  "main": "gulpfile.js",
  "directories": {
    "doc": "docs"
  },
  "dependencies": {
    "bootstrap": "^3.1.1",
    "gulp": "^4.0.2",
    "gulp-concat": "^2.6.1",
    "gulp-less": "^4.0.1",
    "gulp-clean": "^0.4.0",
    "gulp-minify-css": "^1.2.4",
    "gulp-clean-css": "^4.2.0",
    "gulp-sourcemaps": "^2.6.5",
    "gulp-strip-debug": "^3.0.0",
    "gulp-uglify": "^3.0.2",
    "gulp-rename": "^1.4.0",
    "gulp-connect": "^5.7.0"
  },
  "devDependencies": {},
  "scripts": {
    "compat:php85": "bash tests/php_compat/lint_app_php85.sh",
    "compat:php85:deps": "docker compose -f docker-compose-php85.yml run --rm php85 composer validate --strict composer.modern.json",
    "compat:php85:modern-advanced": "bash tests/php_compat/modern_advanced_route.sh",
    "compat:php85:modern-app": "bash tests/php_compat/modern_app.sh",
    "compat:php85:modern-bootstrap": "bash tests/php_compat/modern_bootstrap.sh",
    "compat:php85:modern-bookmark": "bash tests/php_compat/modern_bookmark_route.sh",
    "compat:php85:modern-history": "bash tests/php_compat/modern_history_route.sh",
    "compat:php85:modern-http": "bash tests/php_compat/modern_http.sh",
    "compat:php85:modern-list-filter": "bash tests/php_compat/modern_list_filter_route.sh",
    "compat:php85:modern-mailer": "bash tests/php_compat/modern_mailer.sh",
    "compat:php85:modern-resource": "bash tests/php_compat/modern_resource_route.sh",
    "compat:php85:version": "docker compose -f docker-compose-php85.yml run --rm php85 php -v",
    "smoke": "bash tests/smoke/http_smoke.sh",
    "test": "npm run smoke"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paratiuid/search-journals.git"
  },
  "author": "Scielo.org",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/paratiuid/search-journals/issues"
  },
  "homepage": "https://github.com/paratiuid/search-journals#readme"
}
