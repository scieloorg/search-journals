    "description": "Modern PHP dependency target for the SciELO Search Journals migration.",
    "type": "project",
    "license": "BSD-3-Clause",
    "require": {
        "php": "^8.5",
        "symfony/http-foundation": "^7.0",
        "symfony/http-kernel": "^7.0",
        "symfony/routing": "^7.0",
